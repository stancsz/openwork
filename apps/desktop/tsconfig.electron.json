{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "typeRoots": [
      "../server/node_modules/@types"
    ],
    "types": ["node"]
  },
  "include": [
    "electron/**/*.mjs",
    "scripts/check-electron-bridge.mjs",
    "scripts/electron-build.mjs",
    "scripts/electron-dev.mjs"
  ]
}
