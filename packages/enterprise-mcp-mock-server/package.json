{
  "name": "@openwork/enterprise-mcp-mock-server",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic enterprise OAuth and MCP mock server for development and conformance testing",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/*.test.ts",
    "check": "pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "tsup": "^8.5.0",
    "tsx": "^4.15.7",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
