# Local development defaults for the Den stack.
# Loaded by scripts/dev-local.mjs via process.loadEnvFile().
# Real environment variables always take precedence over these values.
# These are throwaway local-only secrets — never use them in production.
OPENWORK_DEV_MODE=1
DATABASE_URL=mysql://root:password@127.0.0.1:3306/openwork_den
DEN_DB_ENCRYPTION_KEY=local-dev-db-encryption-key-please-change-1234567890
BETTER_AUTH_SECRET=local-dev-secret-not-for-production-use!!
INFERENCE_ADMIN_TOKEN=local-dev-admin-token
INFERENCE_WEBHOOK_SECRET=local-dev-webhook-secret
PROVISIONER_MODE=stub
